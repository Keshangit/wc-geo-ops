# GEO Operations API — copy to .env (never commit .env)

# Required — same value as WC GEO geoOps.apiKey
OPS_API_KEY=change-me-to-a-long-random-string

# Optional — default development
API_HOST=127.0.0.1
API_PORT=8000
LOG_LEVEL=INFO

# Quick audit timeout (seconds)
QUICK_AUDIT_TIMEOUT=60

# Paid tier — Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=8192

# Paid tier — Redis + RQ
REDIS_URL=redis://127.0.0.1:6379/0
JOB_TTL_SECONDS=604800

# Optional webhook when full job completes (WC GEO callback URL)
WC_GEO_WEBHOOK_URL=

# Full audit discovery limits
FULL_SITEMAP_MAX_PAGES=20
FULL_SAMPLE_PAGES=5
